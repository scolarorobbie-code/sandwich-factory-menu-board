{
  "expo": {
    "name": "Sandwich Factory Online",
    "slug": "sandwich-factory-online",
    "scheme": "sandwichfactory",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#15110f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scolaroenterprises.sandwichfactory"
    },
    "android": {
      "package": "com.scolaroenterprises.sandwichfactory"
    },
    "extra": {
      "comment": "EXPO_PUBLIC_API_BASE_URL is read from the environment at build/start time. See src/config.ts."
    }
  }
}
